# Copie para .env (nao commite .env)
GOANIMES_ADDR=:8080
# PORT=8080

# Admin
# GOANIMES_ADMIN_API_KEY=change-me
# ADMIN_API_KEY=change-me

# MongoDB
GOANIMES_MONGO_URI=mongodb://localhost:27017
GOANIMES_MONGO_DB=goanimes

# TMDb
# GOANIMES_TMDB_API_KEY=your-key

# HTTP
# GOANIMES_HTTP_TIMEOUT=45s

# OpenTelemetry
# OTEL_SERVICE_NAME=goanimes
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger.observability.svc.cluster.local:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://jaeger.observability.svc.cluster.local:4318/v1/traces
# OTEL_SDK_DISABLED=true
