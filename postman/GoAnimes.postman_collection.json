{
  "info": {
    "_postman_id": "a1b2c3d4-goanimes-api",
    "name": "GoAnimes",
    "description": "GoAnimes — admin API + URLs do addon Stremio.\n\n**Variaveis de colecao:** `baseUrl`, `adminApiKey`, `feedId`, `sampleFeedUrl`, `seriesId`, `videoId`.\n\n- **Meta / Stream:** use `seriesId` e `videoId` com URL encoding (ex. `tmdb%3A123%3A1`, `tmdb%3A123%3A1%3A5`).\n- **Admin:** se nao usar chave, ajuste Authorization para **No Auth** na pasta Admin.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8080" },
    { "key": "adminApiKey", "value": "" },
    { "key": "feedId", "value": "" },
    { "key": "overrideId", "value": "" },
    { "key": "unmatchedId", "value": "" },
    {
      "key": "sampleFeedUrl",
      "value": "https://www.erai-raws.info/feed/?type=torrent&token=SEU_TOKEN_AQUI"
    },
    { "key": "seriesId", "value": "" },
    { "key": "videoId", "value": "" }
  ],
  "item": [
    {
      "name": "Public (Stremio / health)",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Manifest (addon Stremio)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/manifest.json"
          }
        },
        {
          "name": "Catalog · Trending",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/catalog/anime/goanimes.trending.json"
          }
        },
        {
          "name": "Catalog · Em Exibicao",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/catalog/anime/goanimes.top_airing.json"
          }
        },
        {
          "name": "Catalog · Most Popular",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/catalog/anime/goanimes.most_popular.json"
          }
        },
        {
          "name": "Catalog · Highest Rated",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/catalog/anime/goanimes.highest_rated.json"
          }
        },
        {
          "name": "Catalog · Trending + genre extra",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/catalog/anime/goanimes.trending/genre=Fantasia.json"
          }
        },
        {
          "name": "Meta (anime / series id)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/meta/anime/{{seriesId}}.json"
          }
        },
        {
          "name": "Stream (anime / video id)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/stream/anime/{{videoId}}.json"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{adminApiKey}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "Feeds",
          "item": [
            {
              "name": "Create feed",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const j = pm.response.json();",
                      "  if (j && j.feed && j.feed.id) pm.collectionVariables.set('feedId', j.feed.id);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Erai\",\n  \"url\": \"{{sampleFeedUrl}}\",\n  \"type\": \"rss\",\n  \"enabled\": true\n}"
                },
                "url": "{{baseUrl}}/admin/feeds"
              }
            },
            {
              "name": "Update feed",
              "request": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Erai\",\n  \"url\": \"{{sampleFeedUrl}}\",\n  \"type\": \"rss\",\n  \"enabled\": false\n}"
                },
                "url": "{{baseUrl}}/admin/feeds/{{feedId}}"
              }
            },
            {
              "name": "List feeds",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/admin/feeds"
              }
            },
            {
              "name": "Delete feed",
              "request": {
                "method": "DELETE",
                "header": [],
                "url": "{{baseUrl}}/admin/feeds/{{feedId}}"
              }
            }
          ]
        },
        {
          "name": "Sync",
          "item": [
            {
              "name": "Sync now",
              "request": {
                "method": "POST",
                "header": [],
                "description": "Agenda sync em background. Resposta rapida: HTTP 202 + accepted:true, ou HTTP 200 + accepted:false + reason se ja ha sync a correr.",
                "url": "{{baseUrl}}/admin/sync"
              }
            },
            {
              "name": "Clean feed sources",
              "request": {
                "method": "DELETE",
                "header": [],
                "description": "Remove todas as fontes de um feed específico do banco de dados. Use o ID do feed (ex: faddf736-7aa2-460c-ad95-7909c02c2032). Útil para limpar dados antigos ou incorretos de um feed.",
                "url": "{{baseUrl}}/admin/clean/{{feedId}}"
              }
            }
          ]
        },
        {
          "name": "Mapping overrides",
          "item": [
            {
              "name": "List overrides",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/admin/mapping-overrides"
              }
            },
            {
              "name": "Upsert override",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"rss_name_key\": \"Honzuki no Gekokujou: Ryushu no Youjo\",\n  \"tmdb_id\": 91768,\n  \"season\": 4,\n  \"locked\": true,\n  \"episode_offset\": 48\n}"
                },
                "url": "{{baseUrl}}/admin/mapping-overrides"
              }
            },
            {
              "name": "Delete override",
              "request": {
                "method": "DELETE",
                "header": [],
                "description": "Delete an override by ID. Use the override ID from List overrides response.",
                "url": "{{baseUrl}}/admin/mapping-overrides/{{overrideId}}"
              }
            }
          ]
        },
        {
          "name": "Unmatched",
          "item": [
            {
              "name": "List unmatched",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/admin/unmatched?limit=100"
              }
            },
            {
              "name": "Delete unmatched",
              "request": {
                "method": "DELETE",
                "header": [],
                "description": "Delete an unmatched release by ID. Use the unmatched ID from List unmatched response.",
                "url": "{{baseUrl}}/admin/unmatched/{{unmatchedId}}"
              }
            }
          ]
        }
      ]
    }
  ]
}
